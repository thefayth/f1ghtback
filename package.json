{
  "name": "f1ghtback-one-safe-next-step",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/*.test.mjs",
    "test:unit": "node --experimental-strip-types --test tests/api-next-step.test.mjs tests/api-explain-step.test.mjs tests/guide-packets.test.mjs tests/rendered-html.test.mjs",
    "lint": "eslint --no-ignore app build db scripts tests drizzle.config.ts eslint.config.mjs next.config.ts postcss.config.mjs vite.config.ts",
    "typecheck": "tsc --noEmit",
    "sources:check": "node --experimental-strip-types scripts/check-official-sources.mjs",
    "sources:baseline": "node --experimental-strip-types scripts/check-official-sources.mjs --update-baseline",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^0.577.0",
    "next": "16.2.6",
    "pdf-lib": "^1.17.1",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "overrides": {
    "postcss": "8.5.14"
  },
  "type": "module"
}
